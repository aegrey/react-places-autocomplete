{
  "name": "@aegrey/react-places-autocomplete",
  "version": "7.5.1",
  "description": "A React component for Google Maps Places Autocomplete",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prettier": "prettier --write \"src/**/*.{ts,tsx}\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joshtwc/react-places-autocomplete.git"
  },
  "keywords": [
    "React.js",
    "React",
    "react-component",
    "place",
    "places",
    "google-maps",
    "google-map",
    "places-autocomplete",
    "autocomplete",
    "google",
    "maps",
    "latitude",
    "longitude",
    "geocode",
    "geocoder"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "author": "Ken Hibino <ken.hibino7@gmail.com> (http://www.kenhibino.com/)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kenny-hibino/react-places-autocomplete/issues"
  },
  "homepage": "https://github.com/kenny-hibino/react-places-autocomplete#readme",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@eslint/js": "^10.0.1",
    "@types/google.maps": "^3.65.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  }
}
